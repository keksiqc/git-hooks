{
  "name": "simple-git-hooks",
  "type": "commonjs",
  "version": "2.13.1",
  "description": "A simple, zero dependency tool for setting up git hooks for small projects",
  "author": "Mikhail Gorbunov <toplenboren@gmail.com>",
  "main": "simple-git-hooks.js",
  "bin": "./cli.js",
  "packageManager": "bun@1.3.11",
  "files": [
    "cli.js",
    "postinstall.js",
    "simple-git-hooks.js",
    "uninstall.js"
  ],
  "scripts": {
    "postinstall": "node ./postinstall.js",
    "lint": "eslint *.js",
    "test": "node --experimental-vm-modules ./node_modules/.bin/jest",
    "release": "clean-pkg-json && changeset publish",
    "uninstall": "node ./uninstall.js"
  },
  "keywords": [
    "pre-commit",
    "pre-push",
    "git",
    "hook",
    "lint",
    "linter"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/toplenboren/simple-git-hooks.git"
  },
  "lint-staged": {
    "*.js": "eslint"
  },
  "simple-git-hooks": {
    "pre-commit": "bun lint"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "clean-pkg-json": "^1.4.1",
    "eslint": "^10.1.0",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "lodash.isequal": "^4.5.0",
    "simple-git-hooks": "link:."
  }
}
